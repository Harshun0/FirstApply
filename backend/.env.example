# Server port (Render sets this automatically; locally defaults to 5000)
PORT=5000

# MongoDB Atlas connection string
# e.g. mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/FirstApply?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_uri

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token

# Deployed frontend URL (used in /start message and CORS)
# e.g. https://fresher-alert.vercel.app
FRONTEND_URL=your_vercel_url
